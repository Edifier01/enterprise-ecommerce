# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ecommerce

# Backend
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000"]
# Payment: auto | stub | stripe (auto uses stub when STRIPE_SECRET_KEY is empty)
PAYMENT_PROVIDER=auto

# Stripe (optional — only required when PAYMENT_PROVIDER=stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
# Payment UI: auto | stub | stripe (auto uses stub when publishable key is empty)
NEXT_PUBLIC_PAYMENT_MODE=auto
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# MCP (Cursor — set in OS environment, not committed)
# CONTEXT7_API_KEY=
# GITHUB_PAT=
# SENTRY_AUTH_TOKEN=
