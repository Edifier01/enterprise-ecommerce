# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/ecommerce

# Backend
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000"]
# Payment: auto | stub | stripe (auto uses stub when STRIPE_SECRET_KEY is empty)
PAYMENT_PROVIDER=auto

# Stripe (optional — only required when PAYMENT_PROVIDER=stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Auth email (SMTP configuration — next step; use console in dev)
EMAIL_PROVIDER=console
STOREFRONT_URL=http://localhost:3000
EMAIL_FROM=noreply@example.com
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true
AUTH_VERIFICATION_TOKEN_EXPIRE_HOURS=24
AUTH_RESET_TOKEN_EXPIRE_HOURS=1

# Inventory reservations (ADR-005)
INVENTORY_RESERVATION_TTL_MINUTES=15
INVENTORY_RESERVATION_SWEEP_ENABLED=true
INVENTORY_RESERVATION_SWEEP_INTERVAL_SECONDS=60

# Admin panel (ADR-007) — dev seed credentials
ADMIN_DEV_EMAIL=admin@localhost
ADMIN_DEV_PASSWORD=admin12345
ADMIN_LOW_STOCK_THRESHOLD=5

# MoySklad integration (ADR-010)
MOYSKLAD_API_TOKEN=
MOYSKLAD_STORE_ID=
MOYSKLAD_RETAIL_PRICE_TYPE=Цена продажи
MOYSKLAD_WHOLESALE_PRICE_TYPE=Розница
MOYSKLAD_WEBHOOK_SECRET=
MOYSKLAD_SYNC_CRON_ENABLED=false
MOYSKLAD_SYNC_CRON_INTERVAL_SECONDS=600
MOYSKLAD_ORGANIZATION_ID=
MOYSKLAD_ORDER_EXPORT_ENABLED=true
STOREFRONT_MIN_AVAILABLE_STOCK=3

# After first catalog import, register webhooks (ops CLI — not admin UI):
# python -m scripts.register_moysklad_webhooks --url https://your-domain/api/v1/integrations/moysklad/webhook
# Then enable webhook processing:
# PATCH /api/v1/admin/integrations/moysklad/webhooks/enabled {"enabled": true}

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
# Optional CDN/media base for product images (Wave 3 — see lib/store/product-image.ts)
# NEXT_PUBLIC_CDN_URL=https://cdn.example.com
# NEXT_PUBLIC_MEDIA_BASE_URL=https://media.example.com
# Service worker: true | false | unset (unset = enabled in production only)
# NEXT_PUBLIC_PWA_ENABLED=true
# Payment UI: auto | stub | stripe (auto uses stub when publishable key is empty)
NEXT_PUBLIC_PAYMENT_MODE=auto
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# MCP (Cursor — set in OS environment, not committed)
# CONTEXT7_API_KEY=
# GITHUB_PAT=
# SENTRY_AUTH_TOKEN=
