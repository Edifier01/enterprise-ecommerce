# Production environment — copy to the server as `.env.production`
# NEVER commit the real `.env.production` file to git.
#
# Quick start:
#   cp .env.production.example .env.production
#   ./scripts/generate-production-secrets.sh >> .env.production   # append secrets
#   nano .env.production   # fill DOMAIN, MoySklad
#   ./scripts/deploy.sh

# ── Site & TLS ──────────────────────────────────────────────────────────────
DOMAIN=shop.example.com
ACME_EMAIL=admin@example.com

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-strong-password

# ── API auth (required) ───────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32

# ── Media storage — local filesystem on server ────────────────────────────────
# Public URL for uploaded catalog images (Caddy proxies /media/* to API)
MEDIA_PUBLIC_BASE_URL=https://${DOMAIN}/media
# Path inside API container (must match docker-compose.prod.yml volume mount)
MEDIA_UPLOAD_DIR=/app/uploads
# Max upload size (bytes); default 5242880 = 5 MiB
# MEDIA_MAX_UPLOAD_BYTES=5242880

# ── Payments ─────────────────────────────────────────────────────────────────
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ── Auth email (configure SMTP before go-live) ───────────────────────────────
EMAIL_PROVIDER=console
STOREFRONT_URL=https://${DOMAIN}
EMAIL_FROM=noreply@${DOMAIN}
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true

# ── MoySklad ─────────────────────────────────────────────────────────────────
MOYSKLAD_API_TOKEN=
MOYSKLAD_STORE_ID=
MOYSKLAD_RETAIL_PRICE_TYPE=Цена продажи
MOYSKLAD_WHOLESALE_PRICE_TYPE=Розница
MOYSKLAD_WEBHOOK_SECRET=
MOYSKLAD_SYNC_CRON_ENABLED=false
MOYSKLAD_ORDER_EXPORT_ENABLED=true
STOREFRONT_MIN_AVAILABLE_STOCK=3

# ── Admin ops ────────────────────────────────────────────────────────────────
ADMIN_LOW_STOCK_THRESHOLD=5
ADMIN_INVENTORY_MANUAL_ADJUST_ENABLED=false
# Behind reverse proxy (Caddy): set to 1 so X-Forwarded-For is parsed safely
TRUSTED_PROXY_HOPS=1
# ADMIN_LOGIN_ALLOWED_IPS=
# ADMIN_DEV_EMAIL=
# ADMIN_DEV_PASSWORD=
