# Production environment — copy to the server as `.env.production`
# NEVER commit the real `.env.production` file to git.

# Public site URL (must match DNS A-record)
DOMAIN=shop.example.com

# Let's Encrypt contact email for HTTPS certificate
ACME_EMAIL=admin@example.com

# PostgreSQL (used by docker-compose.prod.yml)
POSTGRES_PASSWORD=change-me-strong-password

# API secrets (required in production)
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32

# Payments: production rejects stub provider. Use stripe until YooKassa is integrated.
PAYMENT_PROVIDER=stripe

# Stripe (optional until payment sprint; leave empty if unused)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Auth email — SMTP configuration (next step; use console in dev until then)
EMAIL_PROVIDER=console
STOREFRONT_URL=https://${DOMAIN}
EMAIL_FROM=noreply@${DOMAIN}
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true
AUTH_VERIFICATION_TOKEN_EXPIRE_HOURS=24
AUTH_RESET_TOKEN_EXPIRE_HOURS=1

# NEXT_PUBLIC_API_URL=https://${DOMAIN}
# Server-side Next.js uses API_INTERNAL_URL=http://api:8000 (set in compose)
